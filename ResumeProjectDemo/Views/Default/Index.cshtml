
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">

		@await Component.InvokeAsync("_DefaultHeadComponentPartial")

<body class="slideshow-background">

	<div id="preloader" class="preloader">
		<div class="loader-status">
			<div class="spinner"></div>
		</div>
	</div>

	<div class="site-container">

		<div id="top"></div>

		<!-- Mobile logo -->
		<a href="#" class="mobile-logo mobile-logo-light bg-dark">
			<span>Dilan Deregözü</span>
		</a>

		<!-- Navigation toggle -->
		<button type="button" id="navigation-toggle" class="nav-toggle nav-toggle-light bg-dark">
			<span></span>
		</button>

		@await Component.InvokeAsync("_DefaultHeaderComponentPartial")

		<!-- Header overlay -->
		<div class="header-overlay">
			<div class="overlay-inner bg-dark opacity-80"></div>
		</div>

		<!-- Back to top button -->
		<button type="button" id="backtotop" class="btn btn-primary btn-icon">
			<span class="btn-icon-inner fas fa-angle-up"></span>
		</button>

		<!-- Page wrapper -->
		<div class="page-wrapper">
			﻿<div id="page-cover" class="page-cover" style="position: relative; height: 100vh; width: 100%; overflow: hidden;">

				<div id="vegas-slider-target" style="position: absolute; top: 0; left: 0; width: 100%; height: 100% !important; z-index: 1;">
					<div class="overlay-inner bg-dark opacity-50" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 2; pointer-events: none;"></div>
				</div>

				<div class="page-cover-wrap" style="position: relative; z-index: 10; width: 100%; height: 100%;">
					<section id="home" class="d-flex vh-100">
						<div class="container-fluid align-self-center text-white text-center px-0">
							<div class="avatar avatar-xxl mb-6 mx-auto">
								<div class="avatar-shape avatar-shape-rounded bg-white mt-n2 mb-n2 mr-n2"></div>
								<img src="/templates/demo/images/dilan.jpg" alt="Dilan" class="avatar-img rounded-circle shadow-light">
							</div>
							<h1 class="text-white font-bold tracking-tight mb-2" style="font-size: 3.5rem;">Dilan Deregözü</h1>
							<p class="lead mb-0 text-gray-200">Full Stack Developer</p>
							<span class="cover-letter letter-xl text-white opacity-10 select-none">D</span>
						</div>
					</section>
                </div>
              
			</div>

			<div class="page-content">

				@await Component.InvokeAsync("_DefaultAboutComponentPartial")
				
				@await Component.InvokeAsync("_DefaultSkillComponentPartial")

				@await Component.InvokeAsync("_DefaultExperinceComponentPartial")

				@await Component.InvokeAsync("_DefaultServiceComponentPartial")

				@await Component.InvokeAsync("_DefaultPortfolioComponentPartial")

				@await Component.InvokeAsync("_DefaultTestimonialComponentPartial")

				@await Component.InvokeAsync("_DefaultContactComponentPartial")

				@await Component.InvokeAsync("_DefaultFooterComponentPartial")
		

				<!-- Site footer -->
			

			</div><!--end .page-content -->
		</div><!-- end .page-wrapper -->

	</div>

	@await Component.InvokeAsync("_DefaultScriptsComponentPartial")

</body>
</html>