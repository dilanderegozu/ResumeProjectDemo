@model List<ResumeProjectDemo.Entities.Portfolio>

<section id="portfolio">

    @await Component.InvokeAsync("_DefaultCategoryComponentPartial");

    <div class="container">
        <div class="portfolio-container isotope-container row my-n2 mx-sm-n2">
            @foreach (var item in Model)
            {
                <div class="isotope-item col-sm-6 col-lg-4 py-2 px-sm-2 category-@item.CategoryId">
                    <div class="portfolio-item details-inside">
                        <a href="@item.ImageUrl" class="image-popup" title="@item.Title">
                            <div class="item-media">
                                <img src="@item.ImageUrl" alt="@item.Title" class="img-fluid">
                            </div>
                            <div class="item-overlay bg-dark"></div>
                            <div class="item-details text-center">
                                <h4 class="h5">@item.Title</h4>
                                <p class="font-italic">Kategori Adı</p>
                            </div>
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- Popup için gerekli CSS -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/magnific-popup.js/1.1.0/magnific-popup.min.css">

<style>
    /* PORTFOLIO GRID EFFECT */
    .portfolio-item .item-media img {
        width: 100%;
        transition: transform .3s ease;
    }

    .portfolio-item:hover .item-media img {
        transform: scale(1.05);
    }

    .item-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        opacity: 0;
        transition: .3s ease;
    }

    .portfolio-item:hover .item-overlay {
        opacity: .5;
        background: #000;
    }

    /* POPUP BACKGROUND*/
    .mfp-bg {
        background: rgba(0,0,0,0.85) !important;
    }

    /* POPUP IMAGE */
    .mfp-img {
        max-width: 90% !important;
        max-height: 80vh !important;
        object-fit: contain;
        border-radius: 6px;
        box-shadow: 0 4px 24px rgba(0,0,0,0.7);
    }

    /* POPUP CONTENT CENTER */
    .mfp-content {
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
    }

    /* TITLE UNDER IMAGE */
    .mfp-title {
        color: #fff;
        font-size: 18px;
        text-align: center;
        margin-top: 10px;
    }

    /* NEXT / PREV ARROWS */
    .mfp-arrow {
        opacity: 0.9;
        background: rgba(0,0,0,0.55);
        width: 56px;
        height: 56px;
        border-radius: 50%;
        position: fixed !important;
        top: 50% !important;
        transform: translateY(-50%);
    }

        .mfp-arrow:hover {
            background: rgba(0,0,0,0.85);
            opacity: 1;
        }

    .mfp-arrow-left {
        left: 25px;
    }

    .mfp-arrow-right {
        right: 25px;
    }

    /* COUNTER */
    .mfp-counter {
        color: #fff;
        font-size: 14px;
        text-align: center;
        margin-top: 8px;
    }
</style>

<!-- jQuery + Magnific Popup JS -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/magnific-popup.js/1.1.0/jquery.magnific-popup.min.js"></script>

<!-- Gallery Popup Script -->
<script>
    $(document).ready(function() {
        $('.image-popup').magnificPopup({
            type: 'image',
            gallery: {
                enabled: true,
                tPrev: 'Önceki',
                tNext: 'Sonraki',
                tCounter: '<span class="mfp-counter">%curr% / %total%</span>'
            },
            image: {
                titleSrc: 'title'
            },
            zoom: {
                enabled: true,
                duration: 300
            }
        });
    });
</script>