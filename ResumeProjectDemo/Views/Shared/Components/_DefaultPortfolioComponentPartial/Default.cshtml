  <script>
    document.querySelectorAll('.portfolio-modern .filter-nav a').forEach(link => {
      link.addEventListener('click', e => {
        e.preventDefault();
        document.querySelectorAll('.portfolio-modern .filter-nav a').forEach(l => l.classList.remove('active'));
        link.classList.add('active');
        const filter = link.dataset.filter;
        document.querySelectorAll('#portfolio-grid .project-card').forEach(card => {
          card.style.display = (filter === 'all' || card.dataset.cats.includes(filter)) ? 'flex' : 'none';
        });
      });
    });
  </script>
