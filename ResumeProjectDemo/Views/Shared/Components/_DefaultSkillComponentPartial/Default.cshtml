@model List<ResumeProjectDemo.Entities.Skill>
<section id="skills" class="bg-light">
	<div class="container">
		<div class="row mb-8">
			<div class="col-lg-10 col-xl-8 mx-lg-auto text-center">
				<div class="section-title h2 mb-3">
					<h2 class="mb-0">Yetenekler</h2>
					<span class="title-letter">Y</span>
				</div>
				<p>
					Backend geliştirme alanında modern teknolojilerle çalışıyor, API geliştirme,
					veritabanı yönetimi ve ölçeklenebilir sistemler üzerine odaklanıyorum.
				</p>
			</div>
		</div>

		<div class="row">
			@foreach (var item in Model)
			{
				<div class="col-md-6 mb-4 mb-md-0">
					<p class="h6 mb-1">@item.Title</p>
					<div class="progress mb-6 rounded-0" style="height:5px">
						<div class="progress-bar" style="width: @item.Value%"></div>
					</div>
				</div>

				<div class="col-md-6">
					<p class="h6 mb-1">@item.Title2</p>
					<div class="progress mb-6 rounded-0" style="height:5px">
						<div class="progress-bar" style="width: @item.Value2%"></div>
					</div>

				</div>
			}
		</div>
	</div>
</section>