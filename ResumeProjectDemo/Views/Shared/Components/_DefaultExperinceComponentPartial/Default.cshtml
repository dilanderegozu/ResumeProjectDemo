@model List<ResumeProjectDemo.Entities.Experience>

<section id="experience" class="experience-section">
    <div class="container">

        <div class="section-header text-center mb-5">
            <p class="section-label">Kariyer</p>
            <h2 class="section-title">Deneyim</h2>
        </div>

        <div class="exp-list">
            @for (int i = 0; i < Model.Count; i++)
            {
                var item = Model[i];
                <div class="exp-item">
                    <div class="exp-left">
                        <span class="exp-index">@((i + 1).ToString("D2"))</span>
                        <p class="exp-title">@item.Title</p>
                        <span class="exp-date">
                            <span class="exp-dot"></span>
                            @item.WorkDate
                        </span>
                    </div>
                    <div class="exp-right">
                        <p class="exp-desc">@item.Description</p>
                    </div>
                </div>
            }
        </div>

    </div>
</section>
<style>
.experience-section {
padding: 5rem 0;
}

.section-label {
font-size: 12px;
font-weight: 500;
letter-spacing: 0.12em;
text-transform: uppercase;
color: #888;
margin-bottom: 0.4rem;
}

.section-title {
font-size: 1.6rem;
font-weight: 600;
color: #1a1a1a;
margin: 0;
}

.exp-list {
display: flex;
flex-direction: column;
}

.exp-item {
display: grid;
grid-template-columns: 1fr 2fr;
gap: 2.5rem;
padding: 2rem 0;
border-top: 1px solid rgba(0, 0, 0, 0.08);
}

.exp-item:last-child {
border-bottom: 1px solid rgba(0, 0, 0, 0.08);
}

.exp-left {
display: flex;
flex-direction: column;
gap: 6px;
}

.exp-index {
font-size: 11px;
font-weight: 500;
color: #aaa;
letter-spacing: 0.06em;
}

.exp-title {
font-size: 15px;
font-weight: 600;
color: #1a1a1a;
margin: 0;
line-height: 1.4;
}

.exp-date {
display: inline-flex;
align-items: center;
gap: 7px;
font-size: 12px;
color: #888;
margin-top: 2px;
}

.exp-dot {
width: 6px;
height: 6px;
border-radius: 50%;
background-color: #ccc;
flex-shrink: 0;
}

.exp-right {
padding-top: 2px;
}

.exp-desc {
font-size: 14px;
color: #555;
line-height: 1.75;
margin: 0;
}

</style>